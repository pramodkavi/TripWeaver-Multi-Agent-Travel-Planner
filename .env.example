# ============================================================
# TripWeaver environment configuration (copy to .env)
# Never commit the real .env file.
# ============================================================

# --- LLM (provider is swappable; default OpenAI) ---
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# --- Upstream travel service backing the MCP servers ---
TRAVEL_SERVICE_BASE_URL=https://standing-fish-574.convex.site

# --- MCP servers (host/port they bind to) ---
HOTEL_MCP_HOST=127.0.0.1
HOTEL_MCP_PORT=8001
FLIGHT_MCP_HOST=127.0.0.1
FLIGHT_MCP_PORT=8002

# --- MCP endpoints the backend connects to (streamable-http) ---
HOTEL_MCP_URL=http://127.0.0.1:8001/mcp
FLIGHT_MCP_URL=http://127.0.0.1:8002/mcp

# --- Backend (FastAPI) ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Comma-separated list of allowed CORS origins (use * only for local dev)
CORS_ALLOW_ORIGINS=*

# --- Frontend (Gradio) ---
TRAVEL_PLANNER_API_URL=http://127.0.0.1:8000/chat
